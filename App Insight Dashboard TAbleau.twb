      <aliases enabled='yes' />
      <column caption='Total Apps' datatype='integer' name='[Calculation_0732592871555072]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([App])' />
      </column>
      <column caption='Average Rating' datatype='real' name='[Calculation_0732592874672129]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Rating])' />
      </column>
      <column caption='Total Installs' datatype='integer' name='[Calculation_0732592877162498]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Installs])' />
      </column>
      <column caption='High Rating %' datatype='real' name='[Calculation_0732592878145539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Rating] &gt;= 4.0 THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/ COUNT([Rating])' />
      </column>
      <column caption='Total Reviews' datatype='integer' name='[Calculation_0732592879329284]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Reviews])' />
      </column>
      <column caption='Success Score' datatype='real' name='[Calculation_0732592880275461]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Rating]) THEN&#13;&#10;    NULL&#13;&#10;ELSE&#13;&#10;(&#13;&#10;    /* 1. Rating score (0–100) */&#13;&#10;    [Rating] * 20&#13;&#10;&#13;&#10;    +&#13;&#10;&#13;&#10;    /* 2. Review score (log base 10, capped at 100) */&#13;&#10;    MIN( LOG([Reviews] + 1) / LOG(10) * 15 , 100 )&#13;&#10;&#13;&#10;    +&#13;&#10;&#13;&#10;    /* 3. Install score (log base 10, capped at 100) */&#13;&#10;    MIN( LOG([Installs] + 1) / LOG(10) * 12 , 100 )&#13;&#10;)&#13;&#10;/ 3&#13;&#10;END' />
      </column>
      <column caption='Install segment' datatype='string' name='[Calculation_0732592905240584]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Installs] &gt;= 10000000 THEN &quot;10M+ (Viral)&quot;&#13;&#10;ELSEIF [Installs] &gt;= 1000000 THEN &quot;1M–10M (Popular)&quot;&#13;&#10;ELSEIF [Installs] &gt;= 100000 THEN &quot;100K–1M (Growing)&quot;&#13;&#10;ELSEIF [Installs] &gt;= 10000 THEN &quot;10K–100K (Emerging)&quot;&#13;&#10;ELSEIF [Installs] &gt;= 1000 THEN &quot;1K–10K (New)&quot;&#13;&#10;ELSE &quot;Under 1K (Niche)&quot;&#13;&#10;END' />
      </column>
